# Variables del SERVIDOR central de la bitácora de relevo (Neb).
# Copiá a un archivo NO versionado (p.ej. inyectado por systemd EnvironmentFile) y poblá.
# NUNCA commitear el token ni la contraseña reales.

# Token Bearer que el servidor exige a los clientes (mismo valor que NEB_LOGBOOK_TOKEN del cliente).
# Generar uno largo y aleatorio, p.ej.: python -c "import secrets; print(secrets.token_urlsafe(48))"
NEB_LOGBOOK_TOKEN=change-me-long-random-token

# Conexión a MariaDB (>=10.5).
NEB_LOGBOOK_DB_HOST=127.0.0.1
NEB_LOGBOOK_DB_PORT=3306
NEB_LOGBOOK_DB_USER=neb_logbook
NEB_LOGBOOK_DB_PASSWORD=change-me
NEB_LOGBOOK_DB_NAME=neb_logbook
