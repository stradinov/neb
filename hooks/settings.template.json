{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $NEB_HOME/hooks/save-approved-plan.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $NEB_HOME/hooks/usage-tracker.sh"
          }
        ]
      }
    ]
  }
}
