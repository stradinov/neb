{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${NEB_HOME:-$HOME/.claude/neb}/hooks/save-approved-plan.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${NEB_HOME:-$HOME/.claude/neb}/hooks/usage-tracker.sh\""
          }
        ]
      }
    ]
  }
}
