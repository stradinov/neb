# Variables de entorno para el shell del dev.
# Copia las líneas relevantes a tu .bashrc o .zshrc.

# Path al checkout local de neb (variable canónica; default: ~/.claude/neb)
export NEB_HOME="$HOME/.claude/neb"

# (opcional) Override del remoto si tu repo está en otro host
# export REPO_URL="github.com/<org>/neb.git"

# (opcional) Backend CENTRAL de la bitácora de relevo (habilita el relevo cross-dev). Sin estas,
# la bitácora es local-only. Además el central es OPT-IN por proyecto: un proyecto publica su trabajo
# solo si su CLAUDE.md trae el marcador `<!-- neb-logbook: central -->`. El token es secreto — NO lo
# commitees. Ver server/INSTALL.md.
# export NEB_LOGBOOK_ENDPOINT="https://tu-host/neb-logbook"
# export NEB_LOGBOOK_TOKEN="<el mismo token configurado en el servidor>"
